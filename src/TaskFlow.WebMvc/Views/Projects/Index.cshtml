@model IEnumerable<TaskFlow.Application.DTOs.ProjectDto>

@{
    ViewData["Title"] = "Dashboard de Proyectos";
    Layout = "_Layout"; 
}

<div class="max-w-7xl mx-auto space-y-8 pb-12">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4">
        <div>
            <h2 class="text-3xl md:text-4xl font-headline font-extrabold text-on-surface tracking-tight">Visión General</h2>
            <p class="text-on-surface-variant text-sm mt-2 max-w-xl">
                Gestiona tus sprints activos, backlogs y el progreso de la academia.
            </p>
        </div>
        <button onclick="toggleProjectModal()" class="bg-primary text-on-primary-container px-6 py-3 rounded-xl font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all flex items-center gap-2 active:scale-95 shrink-0">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Nuevo Proyecto
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-bold">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-error/10 border border-error/20 text-error px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">error</span>
            <span class="text-sm font-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="bg-surface-container-low border border-dashed border-outline-variant/30 rounded-2xl p-16 text-center flex flex-col items-center justify-center">
            <div class="w-20 h-20 bg-surface-container rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant">topic</span>
            </div>
            <h3 class="text-xl font-headline font-bold text-on-surface mb-2">No hay proyectos activos</h3>
            <p class="text-on-surface-variant text-sm mb-6 max-w-md">Inicializa tu primer proyecto en la terminal para comenzar a gestionar tus tareas y flujos de trabajo.</p>
            <button onclick="toggleProjectModal()" class="text-primary font-bold hover:text-primary-dim transition-colors flex items-center gap-2 uppercase tracking-widest text-xs">
                <span class="material-symbols-outlined text-lg">add_circle</span> Crear Proyecto Ahora
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            @foreach (var project in Model)
            {
                var statusColor = project.Status == "Active" ? "bg-primary/20 text-primary border-primary/20" : 
                                  project.Status == "Completed" ? "bg-blue-500/20 text-blue-400 border-blue-500/20" : 
                                  "bg-surface-container-highest text-on-surface-variant border-outline-variant/20";
                
                var statusDot = project.Status == "Active" ? "bg-primary animate-pulse" : 
                                project.Status == "Completed" ? "bg-blue-400" : 
                                "bg-on-surface-variant";

                <div class="bg-surface-container hover:bg-surface-container-high transition-all duration-300 rounded-2xl p-6 border border-outline-variant/10 shadow-lg group relative overflow-visible flex flex-col h-full">
                    
                    <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl -mr-16 -mt-16 group-hover:bg-primary/10 transition-colors pointer-events-none"></div>
                    
                    <div class="relative z-10 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <span class="@statusColor border text-[10px] font-bold px-2.5 py-1 rounded flex items-center gap-1.5 uppercase tracking-wider">
                                <span class="w-1.5 h-1.5 rounded-full @statusDot"></span>
                                @project.Status
                            </span>
                            
                            <div class="relative group/menu">
                                <button type="button" class="text-on-surface-variant hover:text-primary transition-colors p-1 rounded-md hover:bg-surface-container-highest">
                                    <span class="material-symbols-outlined">more_vert</span>
                                </button>
                                <div class="absolute right-0 top-full mt-1 w-40 bg-surface-container-highest border border-outline-variant/20 rounded-lg shadow-xl opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-50 overflow-hidden">
                                    <button type="button" onclick="openEditModal('@project.Id', '@Html.Raw(project.Name)', '@Html.Raw(project.Description)')" class="w-full text-left px-4 py-2 text-sm text-on-surface hover:text-primary hover:bg-surface-container-low transition-colors flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[16px]">edit</span> Editar
                                    </button>
                                    <form asp-action="Delete" asp-route-id="@project.Id" method="post" onsubmit="return confirm('Peligro: Eliminarás este proyecto y sus tareas. ¿Continuar?');">
                                        <button type="submit" class="w-full text-left px-4 py-2 text-sm text-error hover:bg-error/10 transition-colors flex items-center gap-2">
                                            <span class="material-symbols-outlined text-[16px]">delete</span> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        
                        <h3 class="text-xl font-headline font-bold text-on-surface mb-2 group-hover:text-primary transition-colors line-clamp-1">
                            @project.Name
                        </h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed mb-6 line-clamp-2 flex-1">
                            @project.Description
                        </p>
                        
                        <div class="mb-4">
                            <div class="flex justify-between items-center text-xs mb-1.5">
                                <span class="text-on-surface-variant font-medium flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">checklist</span> @project.TotalTasks Tareas
                                </span>
                                <span class="font-bold text-primary">@project.CompletionPercentage%</span>
                            </div>
                            <div class="w-full bg-surface-container-highest rounded-full h-1.5 overflow-hidden">
                                <div class="bg-primary h-full rounded-full transition-all duration-1000" style="width: @project.CompletionPercentage%"></div>
                            </div>
                        </div>
                        
                        <div class="mt-auto pt-4 border-t border-outline-variant/10 flex items-center justify-between">
                            <div class="flex items-center gap-2 text-xs font-mono text-outline-variant">
                                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                @project.CreatedAt.ToString("dd MMM yyyy")
                            </div>
                            
                            <a asp-action="Details" asp-route-id="@project.Id" class="text-sm font-bold text-primary hover:text-primary-dim transition-colors flex items-center gap-1">
                                Ver detalles <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-12">
        <div class="lg:col-span-2 bg-surface-container border border-outline-variant/10 rounded-2xl p-8 relative overflow-hidden">
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl"></div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">monitoring</span> Velocidad del Equipo
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <p class="text-xs uppercase tracking-widest text-on-surface-variant mb-1">Sprint Actual</p>
                    <p class="text-2xl font-bold text-on-surface">68<span class="text-sm text-on-surface-variant">%</span></p>
                    <div class="w-full bg-surface-container-highest rounded-full h-1 mt-2"><div class="bg-blue-400 h-full rounded-full w-[68%]"></div></div>
                </div>
                <div>
                    <p class="text-xs uppercase tracking-widest text-on-surface-variant mb-1">Deuda Técnica</p>
                    <p class="text-2xl font-bold text-on-surface">12<span class="text-sm text-on-surface-variant">%</span></p>
                    <div class="w-full bg-surface-container-highest rounded-full h-1 mt-2"><div class="bg-error h-full rounded-full w-[12%]"></div></div>
                </div>
                <div>
                    <p class="text-xs uppercase tracking-widest text-on-surface-variant mb-1">Eficiencia</p>
                    <p class="text-2xl font-bold text-on-surface">94<span class="text-sm text-on-surface-variant">%</span></p>
                    <div class="w-full bg-surface-container-highest rounded-full h-1 mt-2"><div class="bg-primary h-full rounded-full w-[94%]"></div></div>
                </div>
            </div>
        </div>

        <div class="bg-gradient-to-br from-primary-container to-[#1a253f] rounded-2xl p-8 flex flex-col justify-between shadow-lg">
            <div>
                <h4 class="text-on-primary-container font-headline font-bold text-xl mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined">forum</span> Comunidad
                </h4>
                <p class="text-on-primary-container/80 text-sm leading-relaxed">Aprende a gestionar un Sprint exitoso y mejora tus métricas con la metodología Scrum.</p>
            </div>
            <a asp-controller="Home" asp-action="Community" class="mt-8 bg-surface text-on-surface px-6 py-3 rounded-lg text-sm font-bold shadow-xl hover:scale-105 transition-transform w-full uppercase tracking-wider text-center block">
                Ver Guía Scrum
            </a>
        </div>
    </div>
</div>

<div id="newProjectModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="toggleProjectModal()"></div>
    
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
        <div class="relative bg-surface-container-low border border-outline-variant/20 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:max-w-lg w-full">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-primary-container"></div>
            <div class="px-8 pt-8 pb-6 relative z-10">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">add_box</span> Nuevo Proyecto
                    </h3>
                    <button type="button" onclick="toggleProjectModal()" class="text-on-surface-variant hover:text-error transition-colors p-1 rounded-md hover:bg-error/10">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <form asp-action="Create" method="post" class="space-y-5">
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Nombre</label>
                        <input name="Name" required type="text" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-primary outline-none transition-all placeholder-on-surface-variant/30" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Descripción</label>
                        <textarea name="Description" rows="3" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-primary outline-none transition-all placeholder-on-surface-variant/30 resize-none"></textarea>
                    </div>
                    <div class="pt-6 flex gap-4 border-t border-outline-variant/10 mt-6">
                        <button type="button" onclick="toggleProjectModal()" class="flex-1 py-3 px-4 rounded-lg bg-surface-container-high text-on-surface font-bold text-sm hover:bg-surface-container-highest transition-all border border-outline-variant/10">Cancelar</button>
                        <button type="submit" class="flex-1 py-3 px-4 rounded-lg bg-primary text-on-primary-container font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all">Crear</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="editProjectModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="closeEditModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
        <div class="relative bg-surface-container-low border border-outline-variant/20 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:max-w-lg w-full">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-tertiary-dim to-tertiary"></div>
            <div class="px-8 pt-8 pb-6 relative z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-tertiary-dim">edit_square</span> Editar Proyecto
                    </h3>
                    <button type="button" onclick="closeEditModal()" class="text-on-surface-variant hover:text-error transition-colors p-1 rounded-md hover:bg-error/10">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <form id="editForm" asp-action="Edit" method="post" class="space-y-5">
                    <input type="hidden" id="editProjectId" name="id" />
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Nombre</label>
                        <input id="editProjectName" name="Name" required class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-tertiary-dim outline-none" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Descripción</label>
                        <textarea id="editProjectDesc" name="Description" rows="3" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-tertiary-dim outline-none resize-none"></textarea>
                    </div>
                    <div class="pt-6 flex gap-4 border-t border-outline-variant/10 mt-6">
                        <button type="button" onclick="closeEditModal()" class="flex-1 py-3 px-4 rounded-lg bg-surface-container-high text-on-surface font-bold text-sm hover:bg-surface-container-highest">Cancelar</button>
                        <button type="submit" class="flex-1 py-3 px-4 rounded-lg bg-tertiary-dim text-on-primary-container font-bold text-sm hover:shadow-[0_0_20px_rgba(240,224,74,0.4)]">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal Crear
        function toggleProjectModal() {
            const modal = document.getElementById('newProjectModal');
            modal.classList.toggle('hidden');
        }

        // Modal Editar
        function openEditModal(id, name, desc) {
            document.getElementById('editProjectId').value = id;
            document.getElementById('editProjectName').value = name;
            document.getElementById('editProjectDesc').value = desc;
            
            // Actualiza la URL a la que apuntará el formulario
            document.getElementById('editForm').action = '/Projects/Edit/' + id;
            
            document.getElementById('editProjectModal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('editProjectModal').classList.add('hidden');
        }
        // 2.Topbar)
        document.addEventListener('DOMContentLoaded', () => {
            // Buscamos el input de búsqueda que está en el Topbar
            const searchInput = document.querySelector('input[placeholder="Buscar..."]');
            
            // Buscamos todas las tarjetas de proyectos (que tienen estas clases)
            const projectCards = document.querySelectorAll('.grid > .bg-surface-container');

            if (searchInput && projectCards.length > 0) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase(); // Lo que escribes
                    
                    projectCards.forEach(card => {
                        // Buscamos el título del proyecto (la etiqueta h3)
                        const titleElement = card.querySelector('h3');
                        if (titleElement) {
                            const title = titleElement.textContent.toLowerCase();
                            // Si el título incluye lo que escribes, se muestra; si no, se oculta
                            if (title.includes(term)) {
                                card.style.display = 'flex'; 
                            } else {
                                card.style.display = 'none'; 
                            }
                        }
                    });
                });
            }
        });
    </script>
}