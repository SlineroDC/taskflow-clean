@model TaskFlow.Application.DTOs.ProjectDetailsDto

@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
    
    int progress = Model.TotalTasks > 0 ? (int)Math.Round((double)Model.CompletedTasks / Model.TotalTasks * 100) : 0;
}

<div class="max-w-5xl mx-auto pb-16 space-y-8 relative">
    
    <header class="bg-white dark:bg-surface-container rounded-3xl p-8 border border-slate-200 dark:border-outline-variant/10 shadow-sm dark:shadow-lg relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 dark:bg-primary/5 rounded-full blur-3xl -mr-20 -mt-20"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="px-3 py-1 rounded-full bg-primary/20 text-primary border border-primary/20 text-xs font-bold uppercase tracking-wider flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span> @Model.Status
                    </span>
                    <span class="text-slate-500 dark:text-on-surface-variant text-sm font-mono tracking-widest">ID: @Model.Id.ToString().Substring(0,8)</span>
                </div>
                <h1 class="text-4xl font-headline font-extrabold text-slate-900 dark:text-on-surface mb-2">@Model.Name</h1>
                <p class="text-slate-500 dark:text-on-surface-variant max-w-2xl leading-relaxed">@Model.Description</p>
            </div>
            
            <div class="flex items-center gap-3 shrink-0">
                <a asp-action="Index" class="px-5 py-2.5 rounded-lg border border-slate-300 dark:border-outline-variant/30 text-slate-600 dark:text-on-surface-variant font-bold text-sm hover:bg-slate-50 dark:hover:bg-surface-container-high transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span> Volver
                </a>
                
                <form asp-controller="Projects" asp-action="Complete" method="post" class="shrink-0">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" 
                            class="px-5 py-2.5 rounded-lg font-bold text-sm transition-all flex items-center gap-2 @(progress == 100 ? "bg-primary text-slate-900 dark:text-on-primary-container hover:shadow-lg hover:scale-105" : "bg-slate-100 dark:bg-surface-container-high text-slate-400 dark:text-on-surface-variant cursor-not-allowed opacity-50")"
                            @(progress != 100 ? "disabled" : "")
                            title="@(progress != 100 ? "Debes completar todas las tareas primero" : "Completar Proyecto")">
                        <span class="material-symbols-outlined text-[18px]">done_all</span> Completar Sprint
                    </button>
                </form>
            </div>
        </div>
        
        <div class="mt-8 pt-8 border-t border-slate-100 dark:border-outline-variant/10">
            <div class="flex justify-between items-end mb-3">
                <div class="flex gap-8">
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-on-surface-variant mb-1">Tareas Activas</p>
                        <p class="text-2xl font-bold text-slate-900 dark:text-on-surface">@Model.PendingTasks</p>
                    </div>
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-slate-500 dark:text-on-surface-variant mb-1">Completadas</p>
                        <p class="text-2xl font-bold text-primary">@Model.CompletedTasks</p>
                    </div>
                </div>
                <div class="text-right">
                    <span class="text-3xl font-headline font-black text-slate-900 dark:text-on-surface">@progress%</span>
                </div>
            </div>
            <div class="w-full bg-slate-100 dark:bg-surface-container-highest rounded-full h-2 overflow-hidden border border-slate-200 dark:border-outline-variant/5">
                <div class="bg-primary h-full rounded-full transition-all duration-1000 shadow-[0_0_10px_rgba(152,202,63,0.5)]" style="width: @progress%"></div>
            </div>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-bold">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-error/10 border border-error/20 text-error px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">error</span>
            <span class="text-sm font-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    <section class="bg-white dark:bg-surface-container rounded-2xl border border-slate-200 dark:border-outline-variant/10 overflow-visible shadow-sm dark:shadow-lg relative">
        <div class="p-6 border-b border-slate-200 dark:border-outline-variant/10 flex justify-between items-center bg-slate-50 dark:bg-surface-container-low rounded-t-2xl relative z-30">
            <h3 class="text-lg font-headline font-bold text-slate-900 dark:text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">format_list_bulleted</span> Tareas del Sprint
            </h3>
        </div>

        <div class="divide-y divide-slate-100 dark:divide-outline-variant/5 relative z-20" id="taskList">
            @if (!Model.Tasks.Any())
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-5xl text-slate-300 dark:text-on-surface-variant/30 mb-4">task</span>
                    <p class="text-slate-900 dark:text-on-surface font-bold text-lg">El Backlog está vacío</p>
                    <p class="text-slate-500 dark:text-on-surface-variant text-sm mt-1">Comienza añadiendo la primera tarea técnica para este proyecto.</p>
                </div>
            }
            else
            {
                foreach (var task in Model.Tasks)
                {
                    var priorityColor = task.Priority == "Urgent" ? "bg-error/10 text-error border-error/20" :
                                        task.Priority == "High" ? "bg-orange-500/10 text-orange-500 dark:text-orange-400 border-orange-500/20" :
                                        task.Priority == "Medium" ? "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20" :
                                        "bg-slate-100 dark:bg-surface-container-highest text-slate-500 dark:text-on-surface-variant border-slate-200 dark:border-outline-variant/20";
                    
                    var textClass = task.IsCompleted ? "line-through text-slate-400 dark:text-on-surface-variant opacity-50" : "text-slate-700 dark:text-on-surface";

                    <div class="group flex items-center gap-4 p-4 hover:bg-slate-50 dark:hover:bg-surface-container-high transition-colors" data-task-id="@task.Id">
                        
                        <span class="material-symbols-outlined text-slate-300 dark:text-outline-variant/30 cursor-grab hover:text-slate-500 dark:hover:text-on-surface-variant active:cursor-grabbing">drag_indicator</span>
                        
                        @if (!task.IsCompleted)
                        {
                            <button type="button" onclick="openConfirmModal('¿Completar Tarea?', 'task_alt', 'Esta acción marcará la tarea como terminada en el Sprint.', '/Tasks/Complete', '@task.Id', 'Sí, completar')" 
                                    class="w-6 h-6 shrink-0 rounded-full border-2 border-slate-300 dark:border-outline-variant/50 hover:border-primary flex items-center justify-center transition-colors">
                            </button>
                        }
                        else
                        {
                            <button type="button" onclick="openConfirmModal('¿Reabrir Tarea?', 'undo', 'Esta acción devolverá la tarea al estado de pendiente.', '/Tasks/Uncomplete', '@task.Id', 'Reabrir tarea')" 
                                    class="w-6 h-6 shrink-0 rounded-full border-2 bg-primary border-primary text-slate-900 hover:bg-error hover:border-error hover:text-white flex items-center justify-center transition-colors group/check">
                                <span class="material-symbols-outlined text-[14px] font-bold group-hover/check:hidden">check</span>
                                <span class="material-symbols-outlined text-[14px] font-bold hidden group-hover/check:block">close</span>
                            </button>
                        }
                        
                        <div class="flex-1 min-w-0 flex items-center gap-3">
                            <span class="px-2 py-0.5 rounded border text-[10px] font-bold uppercase tracking-widest @priorityColor">
                                @task.Priority
                            </span>
                            <h4 class="font-medium text-sm truncate @textClass">@task.Title</h4>
                        </div>
                        
                        <div class="relative group/menu shrink-0">
                            <button type="button" class="text-slate-400 dark:text-on-surface-variant hover:text-primary transition-colors p-1 rounded">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                            <div class="absolute right-0 top-full mt-1 w-36 bg-white dark:bg-surface-container-highest border border-slate-200 dark:border-outline-variant/20 rounded-lg shadow-xl opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-50 overflow-hidden">
                                
                                <button type="button" data-id="@task.Id" data-title="@task.Title" data-priority="@task.Priority" onclick="handleEditClick(this)" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-on-surface hover:text-primary hover:bg-slate-50 dark:hover:bg-surface-container-low transition-colors flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">edit</span> Editar
                                </button>
                                
                                <button type="button" onclick="openConfirmModal('¿Eliminar Tarea?', 'delete', '¿Estás seguro de que deseas eliminar permanentemente esta tarea del backlog?', '/Tasks/Delete', '@task.Id', 'Eliminar Tarea', true)" class="w-full text-left px-4 py-2 text-sm text-error hover:bg-error/10 transition-colors flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">delete</span> Eliminar
                                </button>
                                
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="p-4 bg-slate-50/50 dark:bg-surface-container-high/30 border-t border-slate-100 dark:border-outline-variant/5 relative z-10 rounded-b-2xl space-y-3">
            <button onclick="openTaskFormModal('add')" class="w-full flex items-center justify-center gap-2 py-3 rounded-lg border border-dashed border-slate-300 dark:border-outline-variant/30 text-slate-500 dark:text-on-surface-variant hover:text-primary hover:border-primary/50 hover:bg-primary/5 transition-all text-sm font-bold">
                <span class="material-symbols-outlined text-lg">add</span> Añadir nueva tarea
            </button>

            @if (Model.PendingTasks > 0)
            {
                <button type="button" onclick="openConfirmModal('¿Completar Todo?', 'done_all', 'Se marcarán las @Model.PendingTasks tareas pendientes como completadas y el proyecto llegará al 100%.', '/Tasks/CompleteAll', '', '¡Hacerlo!')" 
                        class="w-full flex items-center justify-center gap-2 py-2 rounded-lg text-primary hover:bg-primary/10 transition-all text-xs font-bold uppercase tracking-widest border border-primary/20">
                    <span class="material-symbols-outlined text-sm">checklist</span> Marcar todas como completadas (@Model.PendingTasks)
                </button>
            }
        </div>
    </section>
</div>

<div id="taskFormModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/50 dark:bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="closeTaskFormModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="relative bg-white dark:bg-surface-container-low border border-slate-200 dark:border-outline-variant/20 rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden">
            <div id="taskFormHeaderBar" class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-primary-container"></div>
            <div class="px-8 py-8 relative z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-headline font-bold text-slate-900 dark:text-on-surface flex items-center gap-2">
                        <span id="taskFormIcon" class="material-symbols-outlined text-primary">add_task</span> 
                        <span id="taskFormTitle">Añadir Tarea</span>
                    </h3>
                    <button type="button" onclick="closeTaskFormModal()" class="text-slate-400 dark:text-on-surface-variant hover:text-error transition-colors">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                
                <form id="taskForm" method="post" class="space-y-5">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" id="taskFormId" name="id" value="" />
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-slate-500 dark:text-on-surface-variant uppercase tracking-widest">Título de la Tarea</label>
                        <input id="taskFormTitleInput" name="Title" required type="text" class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-surface-container border border-slate-200 dark:border-outline-variant/20 text-slate-900 dark:text-on-surface focus:ring-2 focus:ring-primary outline-none placeholder-slate-400 dark:placeholder-on-surface-variant/30" />
                    </div>
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-slate-500 dark:text-on-surface-variant uppercase tracking-widest">Prioridad</label>
                        <select id="taskFormPriority" name="PriorityValue" class="w-full px-4 py-3 rounded-lg bg-slate-50 dark:bg-surface-container border border-slate-200 dark:border-outline-variant/20 text-slate-900 dark:text-on-surface focus:ring-2 focus:ring-primary outline-none appearance-none">
                            <option value="0">Baja (Low)</option>
                            <option value="1">Media (Medium)</option>
                            <option value="2">Alta (High)</option>
                            <option value="3">Urgente (Urgent)</option>
                        </select>
                    </div>

                    <div class="pt-6 flex gap-4 border-t border-slate-100 dark:border-outline-variant/10 mt-6">
                        <button type="button" onclick="closeTaskFormModal()" class="flex-1 py-3 px-4 rounded-lg bg-slate-100 dark:bg-surface-container-high text-slate-700 dark:text-on-surface font-bold text-sm hover:bg-slate-200 dark:hover:bg-surface-container-highest transition-all">Cancelar</button>
                        <button type="submit" id="taskFormSubmitBtn" class="flex-1 py-3 px-4 rounded-lg bg-primary text-slate-900 font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="confirmModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/50 dark:bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="closeConfirmModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="relative bg-white dark:bg-surface-container-low border border-slate-200 dark:border-outline-variant/20 rounded-2xl w-full max-w-sm shadow-2xl overflow-hidden text-center p-8 z-10">
            <div id="confirmModalIconContainer" class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4 border border-primary/30">
                <span id="confirmModalIcon" class="material-symbols-outlined text-primary text-3xl">info</span>
            </div>
            <h3 id="confirmModalTitle" class="text-xl font-headline font-bold text-slate-900 dark:text-on-surface mb-2">Confirmación</h3>
            <p id="confirmModalMessage" class="text-slate-500 dark:text-on-surface-variant text-sm mb-6">¿Estás seguro de realizar esta acción?</p>
            
            <form id="confirmModalForm" method="post" class="flex gap-4">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" id="confirmModalTaskId" name="id" value="" />
                
                <button type="button" onclick="closeConfirmModal()" class="flex-1 py-3 rounded-lg border border-slate-200 dark:border-outline-variant/30 text-slate-600 dark:text-on-surface-variant font-bold text-sm hover:bg-slate-50 dark:hover:bg-surface-container-high transition-all">Cancelar</button>
                <button type="submit" id="confirmModalSubmitBtn" class="flex-1 py-3 bg-primary text-slate-900 rounded-lg font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all">Confirmar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
}