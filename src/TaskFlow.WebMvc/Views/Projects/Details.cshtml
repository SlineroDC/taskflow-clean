@model TaskFlow.Application.DTOs.ProjectDetailsDto

@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
    
    // Cálculo de progreso para la barra
    int progress = Model.TotalTasks > 0 ? (int)Math.Round((double)Model.CompletedTasks / Model.TotalTasks * 100) : 0;
}

<div class="max-w-5xl mx-auto pb-16 space-y-8 relative">
    
    <header class="bg-surface-container rounded-3xl p-8 border border-outline-variant/10 shadow-lg relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -mr-20 -mt-20"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="px-3 py-1 rounded-full bg-primary/20 text-primary border border-primary/20 text-xs font-bold uppercase tracking-wider flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span> @Model.Status
                    </span>
                    <span class="text-on-surface-variant text-sm font-mono tracking-widest">ID: @Model.Id.ToString().Substring(0,8)</span>
                </div>
                <h1 class="text-4xl font-headline font-extrabold text-on-surface mb-2">@Model.Name</h1>
                <p class="text-on-surface-variant max-w-2xl leading-relaxed">@Model.Description</p>
            </div>
            
            <div class="flex items-center gap-3 shrink-0">
                <a asp-action="Index" class="px-5 py-2.5 rounded-lg border border-outline-variant/30 text-on-surface-variant font-bold text-sm hover:bg-surface-container-high transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span> Volver
                </a>
                
                <form asp-controller="Projects" asp-action="Complete" method="post" class="shrink-0">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" 
                            class="px-5 py-2.5 rounded-lg font-bold text-sm transition-all flex items-center gap-2 @(progress == 100 ? "bg-primary text-on-primary-container hover:shadow-lg hover:scale-105" : "bg-surface-container-high text-on-surface-variant cursor-not-allowed opacity-50")"
                            @(progress != 100 ? "disabled" : "")
                            title="@(progress != 100 ? "Debes completar todas las tareas primero" : "Completar Proyecto")">
                        <span class="material-symbols-outlined text-[18px]">done_all</span> Completar Sprint
                    </button>
                </form>
            </div>
        </div>
        
        <div class="mt-8 pt-8 border-t border-outline-variant/10">
            <div class="flex justify-between items-end mb-3">
                <div class="flex gap-8">
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Tareas Activas</p>
                        <p class="text-2xl font-bold text-on-surface">@Model.PendingTasks</p>
                    </div>
                    <div>
                        <p class="text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Completadas</p>
                        <p class="text-2xl font-bold text-primary">@Model.CompletedTasks</p>
                    </div>
                </div>
                <div class="text-right">
                    <span class="text-3xl font-headline font-black text-on-surface">@progress%</span>
                </div>
            </div>
            <div class="w-full bg-surface-container-highest rounded-full h-2 overflow-hidden border border-outline-variant/5">
                <div class="bg-primary h-full rounded-full transition-all duration-1000 shadow-[0_0_10px_rgba(152,202,63,0.5)]" style="width: @progress%"></div>
            </div>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-bold">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-error/10 border border-error/20 text-error px-4 py-3 rounded-lg flex items-center gap-3">
            <span class="material-symbols-outlined">error</span>
            <span class="text-sm font-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    <section class="bg-surface-container rounded-2xl border border-outline-variant/10 overflow-visible shadow-lg relative">
        <div class="p-6 border-b border-outline-variant/10 flex justify-between items-center bg-surface-container-low rounded-t-2xl relative z-10">
            <h3 class="text-lg font-headline font-bold text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">format_list_bulleted</span> Tareas del Sprint
            </h3>
        </div>

        <div class="divide-y divide-outline-variant/5 relative z-0" id="taskList">
            @if (!Model.Tasks.Any())
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-5xl text-on-surface-variant/30 mb-4">task</span>
                    <p class="text-on-surface font-bold text-lg">El Backlog está vacío</p>
                    <p class="text-on-surface-variant text-sm mt-1">Comienza añadiendo la primera tarea técnica para este proyecto.</p>
                </div>
            }
            else
            {
                foreach (var task in Model.Tasks)
                {
                    // Determinar el color del badge de prioridad
                    var priorityColor = task.Priority == "Urgent" ? "bg-error/10 text-error border-error/20" :
                                        task.Priority == "High" ? "bg-orange-500/10 text-orange-400 border-orange-500/20" :
                                        task.Priority == "Medium" ? "bg-blue-500/10 text-blue-400 border-blue-500/20" :
                                        "bg-surface-container-highest text-on-surface-variant border-outline-variant/20";
                    
                    var textClass = task.IsCompleted ? "line-through text-on-surface-variant opacity-50" : "text-on-surface";

                    <div class="group flex items-center gap-4 p-4 hover:bg-surface-container-high transition-colors" data-task-id="@task.Id">
                        
                        <span class="material-symbols-outlined text-outline-variant/30 cursor-grab hover:text-on-surface-variant active:cursor-grabbing">drag_indicator</span>
                        
                        <button type="button" onclick="openCompleteTaskModal('@task.Id')" class="w-6 h-6 shrink-0 rounded-full border-2 @(task.IsCompleted ? "bg-primary border-primary text-background pointer-events-none" : "border-outline-variant/50 hover:border-primary") flex items-center justify-center transition-colors">
                            @if(task.IsCompleted) { <span class="material-symbols-outlined text-[14px] font-bold">check</span> }
                        </button>
                        
                        <div class="flex-1 min-w-0 flex items-center gap-3">
                            <span class="px-2 py-0.5 rounded border text-[10px] font-bold uppercase tracking-widest @priorityColor">
                                @task.Priority
                            </span>
                            <h4 class="font-medium text-sm truncate @textClass">@task.Title</h4>
                        </div>
                        
                        <div class="relative group/menu shrink-0">
                            <button type="button" class="text-on-surface-variant hover:text-primary transition-colors p-1 rounded">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                            <div class="absolute right-0 top-full mt-1 w-36 bg-surface-container-highest border border-outline-variant/20 rounded-lg shadow-xl opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all z-20 overflow-hidden">
                                <button type="button" onclick="openEditTaskModal('@task.Id', '@Html.Raw(task.Title)', '@task.Priority')" class="w-full text-left px-4 py-2 text-sm text-on-surface hover:text-primary hover:bg-surface-container-low transition-colors flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[16px]">edit</span> Editar
                                </button>
                                <form asp-controller="Tasks" asp-action="Delete" method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar esta tarea?');">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="projectId" value="@Model.Id" />
                                    <button type="submit" class="w-full text-left px-4 py-2 text-sm text-error hover:bg-error/10 transition-colors flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[16px]">delete</span> Eliminar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="p-4 bg-surface-container-high/30 border-t border-outline-variant/5 relative z-10 rounded-b-2xl space-y-3">
            
            <button onclick="toggleTaskModal()" class="w-full flex items-center justify-center gap-2 py-3 rounded-lg border border-dashed border-outline-variant/30 text-on-surface-variant hover:text-primary hover:border-primary/50 hover:bg-primary/5 transition-all text-sm font-bold">
                <span class="material-symbols-outlined text-lg">add</span>
                Añadir nueva tarea a este proyecto
            </button>

            @if (Model.PendingTasks > 0)
            {
                <form asp-controller="Tasks" asp-action="CompleteAll" method="post">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <button type="submit" onclick="return confirm('¿Completar todas las tareas pendientes de un solo golpe?');" class="w-full flex items-center justify-center gap-2 py-2 rounded-lg text-primary hover:bg-primary/10 transition-all text-xs font-bold uppercase tracking-widest border border-primary/20">
                        <span class="material-symbols-outlined text-sm">checklist</span>
                        Marcar todas como completadas (@Model.PendingTasks)
                    </button>
                </form>
            }
        </div>
    </section>
</div>

<div id="newTaskModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="toggleTaskModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="relative bg-surface-container-low border border-outline-variant/20 rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-primary-container"></div>
            <div class="px-8 py-8 relative z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">add_task</span> Añadir Tarea
                    </h3>
                    <button type="button" onclick="toggleTaskModal()" class="text-on-surface-variant hover:text-error">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                
                <form asp-controller="Tasks" asp-action="Create" method="post" class="space-y-5">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Título de la Tarea</label>
                        <input name="Title" required type="text" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-primary outline-none placeholder-on-surface-variant/30" placeholder="Ej. Implementar autenticación JWT" />
                    </div>
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Prioridad</label>
                        <select name="PriorityValue" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-primary outline-none appearance-none">
                            <option value="0">Baja (Low)</option>
                            <option value="1" selected>Media (Medium)</option>
                            <option value="2">Alta (High)</option>
                            <option value="3">Urgente (Urgent)</option>
                        </select>
                    </div>

                    <div class="pt-6 flex gap-4 border-t border-outline-variant/10 mt-6">
                        <button type="button" onclick="toggleTaskModal()" class="flex-1 py-3 px-4 rounded-lg bg-surface-container-high text-on-surface font-bold text-sm hover:bg-surface-container-highest transition-all">Cancelar</button>
                        <button type="submit" class="flex-1 py-3 px-4 rounded-lg bg-primary text-on-primary-container font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all">Añadir al Sprint</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="editTaskModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="closeEditTaskModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="relative bg-surface-container-low border border-outline-variant/20 rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-tertiary-dim to-tertiary"></div>
            <div class="px-8 py-8 relative z-10">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-tertiary-dim">edit_note</span> Editar Tarea
                    </h3>
                    <button type="button" onclick="closeEditTaskModal()" class="text-on-surface-variant hover:text-error"><span class="material-symbols-outlined">close</span></button>
                </div>
                
                <form asp-controller="Tasks" asp-action="Edit" method="post" class="space-y-5">
                    <input type="hidden" id="editTaskId" name="id" />
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Título de la Tarea</label>
                        <input id="editTaskTitle" name="title" required type="text" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-tertiary-dim outline-none" />
                    </div>
                    
                    <div class="space-y-2">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest">Prioridad</label>
                        <select id="editTaskPriority" name="priorityValue" class="w-full px-4 py-3 rounded-lg bg-surface-container border border-outline-variant/20 text-on-surface focus:ring-2 focus:ring-tertiary-dim outline-none appearance-none">
                            <option value="0">Baja (Low)</option>
                            <option value="1">Media (Medium)</option>
                            <option value="2">Alta (High)</option>
                            <option value="3">Urgente (Urgent)</option>
                        </select>
                    </div>

                    <div class="pt-6 flex gap-4 mt-6 border-t border-outline-variant/10">
                        <button type="button" onclick="closeEditTaskModal()" class="flex-1 py-3 px-4 rounded-lg bg-surface-container-high text-on-surface font-bold text-sm hover:bg-surface-container-highest transition-all">Cancelar</button>
                        <button type="submit" class="flex-1 py-3 px-4 rounded-lg bg-tertiary-dim text-background font-bold text-sm hover:shadow-[0_0_20px_rgba(240,224,74,0.4)] transition-all">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="completeTaskModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#060e1f]/80 backdrop-blur-sm transition-opacity" onclick="closeCompleteTaskModal()"></div>
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="relative bg-surface-container-low border border-outline-variant/20 rounded-2xl w-full max-w-sm shadow-2xl overflow-hidden text-center p-8">
            <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4 border border-primary/30">
                <span class="material-symbols-outlined text-primary text-3xl">task_alt</span>
            </div>
            <h3 class="text-xl font-headline font-bold text-on-surface mb-2">¿Completar Tarea?</h3>
            <p class="text-on-surface-variant text-sm mb-6">Esta acción marcará la tarea como terminada y actualizará las métricas de tu Sprint.</p>
            
            <form asp-controller="Tasks" asp-action="Complete" method="post" class="flex gap-4">
                <input type="hidden" id="completeTaskId" name="id" />
                <input type="hidden" name="projectId" value="@Model.Id" />
                
                <button type="button" onclick="closeCompleteTaskModal()" class="flex-1 py-3 rounded-lg border border-outline-variant/30 text-on-surface-variant font-bold text-sm hover:bg-surface-container-high transition-all">Cancelar</button>
                <button type="submit" class="flex-1 py-3 bg-primary text-on-primary-container rounded-lg font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all">Sí, completar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        // 1. Activar Drag & Drop
        const taskList = document.getElementById('taskList');
        if (taskList) {
            new Sortable(taskList, {
                animation: 150,
                handle: '.cursor-grab', // Solo se arrastra desde el ícono
                ghostClass: 'bg-surface-container-highest', // Color de fondo al arrastrar
                onEnd: function (evt) {
                    // evt.oldIndex y evt.newIndex te dan las posiciones
                    const taskId = evt.item.getAttribute('data-task-id');
                    const newOrder = evt.newIndex + 1;
                    
                    fetch(`/Tasks/Reorder?id=${taskId}&newOrder=${newOrder}`, { method: 'POST' })
                        .then(response => console.log('Orden actualizado en DB'));
                }
            });
        }
        
        // Modal de Añadir
        function toggleTaskModal() { 
            document.getElementById('newTaskModal').classList.toggle('hidden'); 
        }

        // Modal de Edición
        function openEditTaskModal(id, title, priorityStr) {
            document.getElementById('editTaskId').value = id;
            document.getElementById('editTaskTitle').value = title;
            
            // Mapeo inverso de string a valor numérico del enum (0 a 3)
            const priorityMap = { "Low": 0, "Medium": 1, "High": 2, "Urgent": 3 };
            document.getElementById('editTaskPriority').value = priorityMap[priorityStr] || 1;
            
            document.getElementById('editTaskModal').classList.remove('hidden');
        }
        function closeEditTaskModal() { 
            document.getElementById('editTaskModal').classList.add('hidden'); 
        }

        // Modal de Confirmación
        function openCompleteTaskModal(id) {
            document.getElementById('completeTaskId').value = id;
            document.getElementById('completeTaskModal').classList.remove('hidden');
        }
        function closeCompleteTaskModal() { 
            document.getElementById('completeTaskModal').classList.add('hidden'); 
        }
    </script>
}