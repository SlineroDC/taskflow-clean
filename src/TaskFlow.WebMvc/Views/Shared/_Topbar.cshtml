<header class="bg-[#060e1f] border-b border-[#1f2b48] p-4 shrink-0 flex items-center justify-between z-10">
    <div class="flex items-center">
        <div class="relative w-72 md:w-96 group">
            <input type="search" placeholder="Buscar proyectos, tareas..." class="w-full pl-11 pr-4 py-2.5 rounded-xl bg-[#1f2b48] border border-transparent text-[#dee5ff] focus:ring-2 focus:ring-[#98CA3F]/50 focus:border-[#98CA3F] outline-none placeholder-slate-500 transition-all shadow-inner">
            <span class="material-symbols-outlined absolute left-3 top-2.5 text-slate-500 group-focus-within:text-[#98CA3F] transition-colors">search</span>
        </div>
    </div>
    
    <div class="flex items-center gap-4 md:gap-6">
        <button class="relative p-2 text-slate-400 hover:text-[#dee5ff] hover:bg-[#1f2b48] rounded-full transition-all">
            <span class="material-symbols-outlined text-[24px]">notifications</span>
            <span class="absolute top-1 right-1.5 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-[#060e1f]"></span>
        </button>
        
        <div class="w-px h-6 bg-[#1f2b48] hidden md:block"></div>
        
        <button class="flex items-center gap-2 bg-[#98CA3F] text-[#060e1f] px-5 py-2.5 rounded-xl font-bold hover:bg-[#aee254] hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all active:scale-95">
            <span class="material-symbols-outlined text-[20px] font-bold">add</span>
            <span class="hidden md:inline">Nuevo Proyecto</span>
        </button>
    </div>
</header>