<header class="h-16 bg-surface/80 backdrop-blur-md border-b border-outline-variant/15 flex items-center justify-between px-8 sticky top-0 z-30 transition-all">
    
    <div class="flex items-center gap-4">
        <h1 class="text-lg font-headline font-bold text-on-surface">@ViewData["Title"]</h1>
    </div>

    <div class="flex items-center gap-6">
        <div class="hidden md:flex items-center bg-surface-container-high border border-outline-variant/20 rounded-full px-4 py-2 focus-within:ring-2 focus-within:ring-primary focus-within:border-transparent transition-all w-64">
            <span class="material-symbols-outlined text-on-surface-variant text-lg">search</span>
            <input type="text" placeholder="Buscar..." class="bg-transparent border-none outline-none text-sm text-on-surface w-full pl-2 placeholder-on-surface-variant/50" />
            <div class="flex items-center gap-1 ml-2">
                <kbd class="hidden lg:inline-block px-1.5 py-0.5 rounded bg-surface border border-outline-variant/20 text-[10px] font-mono text-on-surface-variant">⌘</kbd>
                <kbd class="hidden lg:inline-block px-1.5 py-0.5 rounded bg-surface border border-outline-variant/20 text-[10px] font-mono text-on-surface-variant">K</kbd>
            </div>
        </div>

        <button class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-2" title="Comunidad Kinetic">
            <span class="material-symbols-outlined">forum</span>
            <span class="hidden lg:block text-sm font-bold">Community</span>
        </button>

        @if (ViewData["ShowNewProjectBtn"] as bool? == true)
        {
            <div class="w-px h-6 bg-outline-variant/20 mx-2"></div> <button data-new-project onclick="toggleProjectModal()" class="bg-primary text-on-primary-container px-4 py-2 rounded-lg font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all flex items-center gap-2 active:scale-95">
                <span class="material-symbols-outlined text-[18px]">add</span> Nuevo
            </button>
        }
    </div>
</header>