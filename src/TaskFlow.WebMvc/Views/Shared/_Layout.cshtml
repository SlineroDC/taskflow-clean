<!DOCTYPE html>
<html lang="es" class="h-full dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    
    <link rel="icon" type="x-ico" href="~/favicon.ico" />
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Inter:wght@100..900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        headline: ['Manrope', 'sans-serif'],
                        body: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        "background": "#060e1f",
                        "on-background": "#dee5ff",
                        "surface": "#0f172a",
                        "surface-container-lowest": "#0b1222",
                        "surface-container-low": "#111a2f",
                        "surface-container": "#15203b",
                        "surface-container-high": "#1b2746",
                        "surface-container-highest": "#223054",
                        "on-surface": "#e2e8f0",
                        "on-surface-variant": "#94a3b8",
                        "outline": "#475569",
                        "outline-variant": "#334155",
                        "primary": "#98CA3F", /* Tu Verde Neón */
                        "on-primary": "#000000",
                        "primary-container": "#203a11",
                        "on-primary-container": "#bcf161",
                        "secondary-container": "#223547",
                        "error": "#ffb4ab",
                        "tertiary-dim": "#f0e04a",
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            background-color: #060e1f;
            color: #dee5ff;
            font-family: 'Inter', sans-serif;
        }
        /* Custom Scrollbar minimalista para los sidebars/modals */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background-color: #334155;
            border-radius: 10px;
        }
    </style>
</head>
<body class="h-full antialiased selection:bg-primary selection:text-black">
    
    <partial name="_Sidebar" />

    <div class="ml-64 flex flex-col min-h-screen relative overflow-hidden z-0 bg-background">
        
        <div class="absolute top-[-20%] left-[-10%] w-[800px] h-[800px] bg-primary/10 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[600px] h-[600px] bg-secondary-container/20 rounded-full blur-[100px] -z-10 pointer-events-none"></div>

        <partial name="_Topbar" />

        <main class="flex-1 p-8 relative z-10 overflow-x-hidden">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>