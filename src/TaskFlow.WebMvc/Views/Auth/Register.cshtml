@{
    ViewData["Title"] = "Crear Cuenta | TaskFlow Kinetic Academy";
    Layout = "_PublicLayout";
    ViewData["BodyClass"] = "bg-background text-on-surface font-body antialiased selection:bg-primary selection:text-on-primary";
}

<a asp-controller="Home" asp-action="Index" class="absolute top-8 left-8 flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-bold z-50 bg-surface-container-highest/50 p-2 pr-4 rounded-full backdrop-blur-md border border-outline-variant/20">
    <span class="material-symbols-outlined">arrow_back</span>
    Volver al Inicio
</a>

<main class="min-h-screen flex flex-col md:flex-row">
    <section class="relative w-full md:w-1/2 min-h-[400px] md:min-h-screen overflow-hidden flex flex-col justify-between p-12 bg-surface-container-lowest">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-surface-container-low via-surface-container-lowest to-surface-container-high opacity-90"></div>
            <div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/10 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-secondary-container/20 rounded-full blur-[100px]"></div>
            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, #40485c 1px, transparent 0); background-size: 40px 40px;"></div>
        </div>
        
        <div class="relative z-10">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary rounded flex items-center justify-center shadow-[0_0_20px_rgba(188,241,97,0.3)]">
                    <span class="material-symbols-outlined text-on-primary-container font-bold" style="font-variation-settings: 'FILL' 1;">bolt</span>
                </div>
                <span class="font-headline text-2xl font-black text-primary uppercase tracking-widest">TaskFlow</span>
            </div>
        </div>
        
        <div class="relative z-10 max-w-lg mt-12 md:mt-0">
            <p class="text-primary font-headline font-bold text-sm tracking-[0.2em] uppercase mb-4">Kinetic Academy</p>
            <h1 class="font-headline text-4xl md:text-5xl font-extrabold text-on-surface leading-tight tracking-tighter mb-8">
                Inicia tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Carrera</span> con nosotros.
            </h1>
            <p class="text-on-surface-variant text-lg font-light leading-relaxed max-w-md">
                Únete a la academia y comienza a gestionar proyectos de software con las mejores prácticas de la industria.
            </p>
        </div>
        
        <div class="relative z-10 pt-12">
            <div class="flex flex-wrap gap-8 md:gap-12 items-center">
                <div>
                    <p class="text-2xl font-headline font-bold text-on-surface">12k+</p>
                    <p class="text-[10px] uppercase tracking-widest text-on-surface-variant mt-1 font-bold">Estudiantes Activos</p>
                </div>
            </div>
        </div>
    </section>

    <section class="w-full md:w-1/2 min-h-screen bg-surface flex items-center justify-center p-6 md:p-12 lg:p-24 relative">
        <div class="w-full max-w-md space-y-8 relative z-10">
            <div class="space-y-2">
                <h2 class="font-headline text-3xl font-bold tracking-tight text-on-surface">Crear Cuenta</h2>
                <p class="text-on-surface-variant font-medium">Completa tus datos para ingresar a la terminal.</p>
            </div>
            
            <form action="#" method="post" class="space-y-5">
                <div class="space-y-2">
                    <label class="block text-sm font-semibold tracking-wide text-on-surface-variant uppercase">Nombre Completo</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant group-focus-within:text-primary transition-colors">person</span>
                        </div>
                        <input class="block w-full pl-12 pr-4 py-4 bg-surface-container-high border-none text-on-surface rounded-lg focus:ring-2 focus:ring-primary focus:bg-surface-container-highest transition-all duration-300 placeholder-on-surface-variant/30" name="fullName" placeholder="Ej. Sebastian Developer" required type="text"/>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold tracking-wide text-on-surface-variant uppercase">Correo Electrónico</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant group-focus-within:text-primary transition-colors">mail</span>
                        </div>
                        <input class="block w-full pl-12 pr-4 py-4 bg-surface-container-high border-none text-on-surface rounded-lg focus:ring-2 focus:ring-primary focus:bg-surface-container-highest transition-all duration-300 placeholder-on-surface-variant/30" name="email" placeholder="nombre@kinetic.academy" required type="email"/>
                    </div>
                </div>
                
                <div class="space-y-2">
                    <label class="block text-sm font-semibold tracking-wide text-on-surface-variant uppercase">Clave de Seguridad</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant group-focus-within:text-primary transition-colors">lock</span>
                        </div>
                        <input id="regPassword" class="block w-full pl-12 pr-12 py-4 bg-surface-container-high border-none text-on-surface rounded-lg focus:ring-2 focus:ring-primary focus:bg-surface-container-highest transition-all duration-300 placeholder-on-surface-variant/30" name="password" placeholder="••••••••••••" required type="password"/>
                        <button type="button" onclick="togglePassword('regPassword', 'eyeIconReg1')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant hover:text-on-surface transition-colors">
                            <span id="eyeIconReg1" class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold tracking-wide text-on-surface-variant uppercase">Confirmar Clave</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant group-focus-within:text-primary transition-colors">verified_user</span>
                        </div>
                        <input id="regConfirm" class="block w-full pl-12 pr-12 py-4 bg-surface-container-high border-none text-on-surface rounded-lg focus:ring-2 focus:ring-primary focus:bg-surface-container-highest transition-all duration-300 placeholder-on-surface-variant/30" name="confirmPassword" placeholder="••••••••••••" required type="password"/>
                        <button type="button" onclick="togglePassword('regConfirm', 'eyeIconReg2')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant hover:text-on-surface transition-colors">
                            <span id="eyeIconReg2" class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="w-full group relative flex items-center justify-center py-4 px-6 bg-gradient-to-r from-primary to-primary-container text-on-primary-container font-headline font-bold rounded-lg overflow-hidden transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-[0_0_20px_rgba(152,202,63,0.3)] hover:shadow-[0_0_30px_rgba(152,202,63,0.5)] mt-6">
                    <span class="relative z-10 flex items-center gap-2 uppercase tracking-widest text-sm">
                        Registrar Usuario
                        <span class="material-symbols-outlined text-lg">arrow_forward</span>
                    </span>
                    <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </button>
            </form>
            
            <p class="text-center text-on-surface-variant text-sm font-medium pt-4">
                ¿Ya tienes una cuenta? 
                <a asp-controller="Auth" asp-action="Login" class="text-primary font-bold hover:underline decoration-2 underline-offset-4 ml-1">Inicia sesión</a>
            </p>
        </div>
    </section>
</main>
<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }
</script>
