@{
    ViewData["Title"] = "Configuración";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto space-y-8 pb-12">
    <div class="bg-surface-container rounded-2xl border border-outline-variant/10 overflow-hidden">
        <div class="p-8 border-b border-outline-variant/10">
            <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-primary">person</span> Perfil de Cuenta
            </h3>
            <p class="text-sm text-on-surface-variant">Información personal y preferencias de tu cuenta.</p>
        </div>
        <div class="p-8 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Nombre Completo</label>
                    <input disabled value="@User.Identity?.Name" class="w-full px-4 py-3 rounded-lg bg-surface-container-high border border-outline-variant/10 text-on-surface opacity-70 cursor-not-allowed" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase tracking-widest mb-2">Correo Electrónico</label>
                    <input disabled value="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" class="w-full px-4 py-3 rounded-lg bg-surface-container-high border border-outline-variant/10 text-on-surface opacity-70 cursor-not-allowed" />
                </div>
            </div>
            <div class="pt-4 flex justify-end">
                <button class="bg-surface-container-highest text-on-surface-variant px-6 py-2 rounded-lg font-bold text-sm cursor-not-allowed">Solicitar Cambio de Datos</button>
            </div>
        </div>
    </div>

    <div class="bg-surface-container rounded-2xl border border-outline-variant/10 overflow-hidden">
        <div class="p-8 border-b border-outline-variant/10">
            <h3 class="text-xl font-headline font-bold text-on-surface flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-tertiary-dim">palette</span> Apariencia (Próximamente)
            </h3>
        </div>
        <div class="p-8">
            <div class="flex items-center justify-between p-4 bg-surface-container-high rounded-lg border border-outline-variant/20">
                <div>
                    <p class="font-bold text-on-surface">Modo Kinetic (Dark Theme)</p>
                    <p class="text-sm text-on-surface-variant">El tema oscuro está activado por defecto para proteger tu vista.</p>
                </div>
                <div class="w-12 h-6 bg-primary rounded-full relative cursor-not-allowed opacity-80">
                    <div class="absolute right-1 top-1 w-4 h-4 bg-on-primary-container rounded-full shadow"></div>
                </div>
            </div>
        </div>
    </div>
</div>