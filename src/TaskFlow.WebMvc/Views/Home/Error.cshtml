@{
    var is403 = ViewBag.StatusCode == 403;
    var errorCode = is403 ? "403" : "404";
    var errorTitle = is403 ? "Acceso Denegado" : "Sistema no encontrado";
    var errorDesc = is403 ? "No tienes autorización para acceder a este sector de la terminal." : "La ruta especificada no existe en la arquitectura del sistema.";
    var errorIcon = is403 ? "lock" : "search_off";
    
    ViewData["Title"] = $"Error {errorCode}";
    Layout = "_PublicLayout";
    ViewData["BodyClass"] = "bg-background text-on-background font-body selection:bg-primary selection:text-on-primary-container overflow-x-hidden";
}

<nav class="fixed top-0 left-0 right-0 z-50 bg-[#060e1f]/80 backdrop-blur-xl flex justify-between items-center h-16 px-8 transition-all border-b border-outline-variant/10">
    <a asp-controller="Home" asp-action="Index" class="text-2xl font-black text-primary uppercase tracking-widest hover:text-primary-dim transition-colors">TaskFlow</a>
    <div class="flex items-center gap-4">
        <a asp-controller="Home" asp-action="Index" class="bg-surface-container-high text-on-surface px-5 py-2 rounded font-bold text-xs uppercase tracking-wider hover:bg-surface-container-highest transition-all border border-outline-variant/20 flex items-center gap-2">
            <span class="material-symbols-outlined text-[16px]">home</span>
            Retornar
        </a>
    </div>
</nav>

<main class="relative pt-16 min-h-screen flex items-center justify-center">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-error/5 kinetic-blob rounded-full pointer-events-none"></div>
    
    <div class="max-w-4xl mx-auto px-8 w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
        <div class="space-y-8 text-center md:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-error/10 border border-error/20 text-error">
                <span class="material-symbols-outlined text-[16px]">warning</span>
                <span class="text-[0.6875rem] font-bold uppercase tracking-widest">Alerta de Sistema</span>
            </div>
            
            <h1 class="font-headline text-8xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-br from-error to-error-container tracking-tighter">
                @errorCode
            </h1>
            
            <div class="space-y-4">
                <h2 class="text-3xl font-bold text-on-surface">@errorTitle</h2>
                <p class="text-on-surface-variant text-lg">@errorDesc</p>
            </div>
            
            <div class="pt-4 flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
                <a asp-controller="Home" asp-action="Index" class="bg-primary text-on-primary-container px-6 py-3 rounded-lg font-bold text-sm hover:shadow-[0_0_20px_rgba(152,202,63,0.4)] transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Regresar al Dashboard
                </a>
            </div>
        </div>
        
        <div class="hidden md:block relative">
            <div class="glass-panel border border-error/20 rounded-2xl p-8 shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-error/5 to-transparent"></div>
                <div class="relative z-10 flex flex-col gap-6">
                    <div class="flex justify-between items-center border-b border-outline-variant/10 pb-4">
                        <span class="font-mono text-xs text-error">SYS_ERR_@errorCode</span>
                        <span class="material-symbols-outlined text-error animate-pulse">@errorIcon</span>
                    </div>
                    
                    <div class="space-y-3 font-mono text-xs text-on-surface-variant/70">
                        <p>> Inicializando diagnóstico...</p>
                        <p>> Buscando en base de datos...</p>
                        <p class="text-error">> @errorDesc</p>
                        <p>> Acción sugerida: Retornar al inicio.</p>
                        <p class="animate-pulse">_</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>